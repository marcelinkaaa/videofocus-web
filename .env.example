# Port the Node.js server listens on internally
PORT=3000

# Shared secret between the iOS app and the server
API_KEY=replace_with_a_long_random_string

# The public-facing origin (used in the player HTML)
PUBLIC_ORIGIN=https://api.videofocus.app

# Rate limit: max requests per minute per IP
RATE_LIMIT_RPM=60

# Redis connection URL
REDIS_URL=redis://redis:6379

# yt-dlp sidecar URL (internal Docker service)
YT_DLP_SIDECAR_URL=http://ytdlp-sidecar:3001

# yt-dlp extraction timeout in milliseconds
YT_DLP_TIMEOUT=15000

# Stream URL cache TTL in seconds (default: 5 hours)
STREAM_CACHE_TTL=18000

# Default preferred video quality (pixel height)
DEFAULT_QUALITY=720

# Video ID for periodic health checks
HEALTH_CHECK_VIDEO_ID=dQw4w9WgXcQ
